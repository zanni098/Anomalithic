# Provider selection. Explicit id wins; otherwise the runtime auto-resolves, preferring
# the zero-cost Free Models Router. One of:
#   free-router | openrouter | openai | gemini | ollama | anthropic | mock
ANOMALITHIC_PROVIDER=free-router

# Free Models Router / OpenRouter (OpenAI-compatible). Free models cost nothing.
OPENROUTER_API_KEY=

# Anthropic (Claude) — native API
ANTHROPIC_API_KEY=

# OpenAI (or any OpenAI-compatible endpoint via OPENAI_BASE_URL)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# Google Gemini (OpenAI-compatible endpoint)
GOOGLE_API_KEY=

# Local models via Ollama
OLLAMA_BASE_URL=http://localhost:11434/v1

# Optional: stable HMAC key so signed thinking-impressions verify across restarts.
ANOMALITHIC_IMPRESSION_KEY=
