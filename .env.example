# Which provider to use: anthropic | openai
ANOMALITHIC_PROVIDER=anthropic
ANOMALITHIC_MODEL=claude-sonnet-4-6

# Anthropic (api key auth)
ANTHROPIC_API_KEY=

# OpenAI-compatible: works with OpenAI, OpenRouter, Ollama, or any local endpoint.
# Set OPENAI_BASE_URL to point at a different backend (e.g. http://localhost:11434/v1 for Ollama).
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# Ads (killer feature) — off by default in Phase 0; placeholder rendering only.
ANOMALITHIC_ADS=off
