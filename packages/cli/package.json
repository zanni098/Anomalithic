{
  "name": "@anomalithic/cli",
  "version": "0.0.0",
  "type": "module",
  "description": "The `anomalithic` command-line interface.",
  "license": "Apache-2.0",
  "bin": {
    "anomalithic": "./dist/index.js"
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup src/index.ts --format esm --clean",
    "dev": "tsup src/index.ts --format esm --watch",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anomalithic/core": "workspace:*",
    "@anomalithic/providers": "workspace:*",
    "@anomalithic/memory": "workspace:*",
    "@anomalithic/mcp": "workspace:*",
    "@anomalithic/plugins": "workspace:*",
    "@anomalithic/skills": "workspace:*",
    "@anomalithic/tui": "workspace:*",
    "commander": "^13.0.0",
    "dotenv": "^16.4.7"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsup": "^8.3.5",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  }
}
