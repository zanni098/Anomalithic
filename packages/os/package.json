{
  "name": "@anomalithic/os",
  "version": "0.0.0",
  "type": "module",
  "description": "The Anomalithic agentic-OS kernel: composes providers, tools, memory, skills, hooks, MCP, orchestration, and security into one runtime.",
  "license": "Apache-2.0",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "dev": "tsup src/index.ts --format esm --dts --watch",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anomalithic/core": "workspace:*",
    "@anomalithic/providers": "workspace:*",
    "@anomalithic/memory": "workspace:*",
    "@anomalithic/skills": "workspace:*",
    "@anomalithic/hooks": "workspace:*",
    "@anomalithic/mcp": "workspace:*",
    "@anomalithic/orchestrator": "workspace:*",
    "@anomalithic/security": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsup": "^8.3.5",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  }
}
