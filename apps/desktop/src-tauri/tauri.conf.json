{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Anomalithic",
  "version": "0.2.0",
  "identifier": "ai.anomalithic.desktop",
  "build": {
    "frontendDist": "../../web/out",
    "devUrl": "http://localhost:4520",
    "beforeDevCommand": "pnpm --filter @anomalithic/web dev",
    "beforeBuildCommand": "pnpm --filter @anomalithic/web build"
  },
  "app": {
    "windows": [
      {
        "title": "Anomalithic",
        "width": 1200,
        "height": 820,
        "minWidth": 720,
        "minHeight": 560,
        "theme": null
      }
    ],
    "security": { "csp": null }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/icon.ico", "icons/icon.icns"]
  }
}
