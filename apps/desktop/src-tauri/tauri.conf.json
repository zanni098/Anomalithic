{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Anomalithic",
  "version": "0.1.0",
  "identifier": "dev.anomalithic.desktop",
  "build": {
    "frontendDist": "../ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Anomalithic",
        "width": 1120,
        "height": 740,
        "minWidth": 720,
        "minHeight": 480,
        "theme": "Dark"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "DeveloperTool",
    "shortDescription": "One agent to rule them all.",
    "longDescription": "Anomalithic — an open-core, model-agnostic AI agent runtime.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
